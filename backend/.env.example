# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/vehicle_service_db

# Port the API server runs on
PORT=5000

# Secret used to sign JWT tokens - change this to a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Default admin account created by the seed script
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@autocare.com
ADMIN_PASSWORD=Admin@12345

# Comma separated list of allowed frontend origins (CORS)
CLIENT_URL=http://localhost:5173
